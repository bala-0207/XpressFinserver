# =============================================================================
# XpressFinserve — Environment Variables Template
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit it. Never paste keys in chat.
# =============================================================================

# ----------------------------------------------------------------------------
# Resend — transactional email for the Get Your Quote lead form
# ----------------------------------------------------------------------------
# Get your key from https://resend.com/api-keys
# Format: re_xxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_paste_your_key_here

# ----------------------------------------------------------------------------
# Email addresses
# ----------------------------------------------------------------------------
# Where leads are delivered (the recipient who acts on them).
LEAD_TO_EMAIL=silambarasan@xpressfinserve.com

# The "From" address for outgoing lead notifications.
#   - Before domain verification: use Resend's test address:
#       LEAD_FROM_EMAIL=XpressFinserve Leads <onboarding@resend.dev>
#   - After verifying xpressfinserve.com in Resend dashboard:
#       LEAD_FROM_EMAIL=XpressFinserve Leads <noreply@xpressfinserve.com>
LEAD_FROM_EMAIL=XpressFinserve Leads <onboarding@resend.dev>
